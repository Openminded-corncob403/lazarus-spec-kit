{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./doc/**)",
      "Read(./examples/**)",
      "Read(**/lib/**)",
      "Read(**/units/**)",
      "Read(**/backup/**)",
      "Read(**/*.ppu)",
      "Read(**/*.o)",
      "Read(**/*.a)",
      "Read(**/*.compiled)",
      "Read(**/*.res)",
      "Read(**/*.rsj)",
      "Read(**/*.lps)",
      "Read(*.pdf)",
      "Read(**/*.png)",
      "Read(**/*.jpg)",
      "Read(**/*.jpeg)",
      "Read(**/*.gif)",
      "Read(**/*.ico)",
      "Read(**/*.bak)",
      "Read(**/*.orig)",
      "Read(**/*.swp)"
    ]
  }
}
